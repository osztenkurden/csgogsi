{
	"name": "csgogsi",
	"version": "4.1.1",
	"description": "",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@eslint/js": "^9.36.0",
		"@types/bun": "^1.2.17",
		"@types/lodash.merge": "^4.6.9",
		"@types/node": "^22.18.8",
		"@typescript/native-preview": "^7.0.0-dev.20260413.1",
		"eslint": "^9.36.0",
		"istanbul-badges-readme": "^1.2.1",
		"lodash.merge": "^4.6.2",
		"prettier": "^3.0.3",
		"ts-toolbelt": "^9.6.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1"
	},
	"scripts": {
		"test": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text",
		"typecheck": "tsgo",
		"make-badges": "bun run scripts/lcov-to-summary.ts && istanbul-badges-readme",
		"rollup": "tsdown tsc/index.ts --format cjs,esm --dts -d dist",
		"build": "npm run rollup",
		"lint": "eslint .",
		"prettier-format": "prettier --config .prettierrc --write tsc/*.ts",
		"format": "npm run prettier-format && npm run lint && npm test && npm run make-badges"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/osztenkurden/csgogsi.git"
	},
	"author": "",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/osztenkurden/csgogsi/issues"
	},
	"homepage": "https://github.com/osztenkurden/csgogsi#readme"
}
